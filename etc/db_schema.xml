<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="coinify_payment_intent" resource="default" engine="innodb" comment="Coinify Payment Intents">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="order_id" nullable="true" length="50" comment="Magento Order Increment ID"/>
        <column xsi:type="varchar" name="payment_intent_id" nullable="true" length="255" comment="Coinify PaymentIntent ID"/>
        <column xsi:type="varchar" name="state" nullable="true" length="50" comment="PaymentIntent state"/>
        <column xsi:type="varchar" name="state_reason" nullable="true" length="255" comment="PaymentIntent state reason"/>
        <column xsi:type="text" name="payment_window_url" nullable="true" comment="Payment Window URL"/>
        <column xsi:type="text" name="response_raw" nullable="true" comment="Raw API response JSON"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="COINIFY_ORDER_ID_IDX">
            <column name="order_id"/>
        </index>
        <index referenceId="COINIFY_PAYMENT_INTENT_ID_IDX">
            <column name="payment_intent_id"/>
        </index>
    </table>
    
    <table name="coinify_payment_refund" resource="default" engine="innodb" comment="Coinify Payment Refunds">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="refund_id" nullable="true" length="255" comment="Coinify Refund ID"/>
        <column xsi:type="varchar" name="payment_intent_id" nullable="true" length="255" comment="PaymentIntent ID"/>
        <column xsi:type="varchar" name="order_id" nullable="true" length="50" comment="Magento Order Increment ID"/>
        <column xsi:type="decimal" name="amount" nullable="true" precision="12" scale="4" comment="Refund amount"/>
        <column xsi:type="varchar" name="currency" nullable="true" length="10" comment="Currency"/>
        <column xsi:type="varchar" name="state" nullable="true" length="50" comment="Refund state"/>
        <column xsi:type="text" name="response_raw" nullable="true" comment="Raw API response JSON"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="COINIFY_REFUND_INTENT_IDX">
            <column name="payment_intent_id"/>
        </index>
        <index referenceId="COINIFY_REFUND_ORDER_IDX">
            <column name="order_id"/>
        </index>
    </table>

    <table name="coinify_webhook_log" resource="default" engine="innodb" comment="Coinify Webhook Logs">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="event" nullable="true" length="100" comment="Webhook event"/>
        <column xsi:type="text" name="payload" nullable="true" comment="Webhook payload JSON"/>
        <column xsi:type="text" name="headers" nullable="true" comment="Webhook headers"/>
        <column xsi:type="varchar" name="payment_intent_id" nullable="true" length="255" comment="PaymentIntent ID"/>
        <column xsi:type="varchar" name="order_id" nullable="true" length="50" comment="Order Increment ID"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="COINIFY_WEBHOOK_INTENT_IDX">
            <column name="payment_intent_id"/>
        </index>
        <index referenceId="COINIFY_WEBHOOK_ORDER_IDX">
            <column name="order_id"/>
        </index>
    </table>
</schema>
