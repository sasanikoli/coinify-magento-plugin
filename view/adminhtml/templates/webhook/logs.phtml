<?php
/** @var \Coinify\Payment\Block\Adminhtml\Webhook\Logs $block */
$logs = $block->getLogs();
?>
<div class="admin__data-grid-wrap">
    <?php if (empty($logs)): ?>
        <p><?= __('No webhook logs found.') ?></p>
    <?php else: ?>
        <table class="data-grid">
            <thead>
                <tr>
                    <th><?= __('ID') ?></th>
                    <th><?= __('Event') ?></th>
                    <th><?= __('Order ID') ?></th>
                    <th><?= __('Payment Intent ID') ?></th>
                    <th><?= __('Received') ?></th>
                    <th><?= __('Payload') ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($logs as $log): ?>
                <tr>
                    <td><?= (int)$log['entity_id'] ?></td>
                    <td><?= $block->escapeHtml($log['event'] ?? '') ?></td>
                    <td><?= $block->escapeHtml($log['order_id'] ?? '') ?></td>
                    <td><?= $block->escapeHtml($log['payment_intent_id'] ?? '') ?></td>
                    <td><?= $block->escapeHtml($log['created_at'] ?? '') ?></td>
                    <td style="max-width:400px;word-break:break-all;font-size:11px"><?= $block->escapeHtml($log['payload'] ?? '') ?></td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    <?php endif; ?>
</div>
