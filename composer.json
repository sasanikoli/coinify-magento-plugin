{
    "name": "coinify/magento2-payment",
    "description": "Coinify cryptocurrency payment gateway for Magento 2",
    "type": "magento2-module",
    "license": "MIT",
    "require": {
        "php": ">=7.4.0",
        "magento/framework": ">=103.0",
        "magento/module-sales": ">=103.0",
        "magento/module-payment": ">=100.3",
        "magento/module-store": ">=101.0",
        "magento/module-checkout": ">=100.3",
        "magento/module-config": ">=101.0",
        "magento/module-ui": ">=101.2"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Coinify\\Payment\\": ""
        }
    },
    "extra": {
        "magento-module-map": {
            "Coinify_Payment": {
                "source": "."
            }
        }
    }
}
